#!/usr/bin/env python3
"""Pre-commit git hook — Mechanism C-1 per B-301 + B-307 + B-308 closures.

Per B-308 (2026-05-16 user-direction "update it to be a code quality layer
as well"): delegates to `tools/pre_commit_checks.py` orchestrator which runs
4 Phase 1 checks:

1. query_blindspots scan (existing discipline-drift check; 4 rules)
2. pytest on changed Python files (unit + regression for changed code)
3. markdown cross-reference resolution (D-N/B-N/R-N/RB-N/SP-N exists)
4. CLI compliance for new tools (D74 exit codes + D75 --dry-run + D76 EVENT_TYPE)

BLOCKS on any check failure (per user D-answer "BLOCK on failures" 2026-05-16).
Producer cannot bypass mechanically without `--no-verify` (self-flagging).

Companion: `.githooks/commit-msg` does exemption-phrase check per B-307 split.

Installation (one-time per clone): `git config core.hooksPath .githooks`
(activates BOTH pre-commit + commit-msg hooks atomically). Recommended:
`python tools/install_pre_commit_hook.py --install --apply` per B-305.

Limitations (acknowledged per fractal-pattern reality):
- Hook cannot invoke Claude API directly from git substrate
- Hook cannot enforce on its own authoring commit (chicken-and-egg)
- Hook bypassable via `--no-verify`; self-flagging only
"""
from __future__ import annotations

import subprocess
import sys
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parent.parent
ORCHESTRATOR_PATH = REPO_ROOT / "tools" / "pre_commit_checks.py"


def _venv_python() -> str:
    """Detect project venv Python interpreter; fall back to sys.executable."""
    win_venv = REPO_ROOT / ".venv" / "Scripts" / "python.exe"
    posix_venv = REPO_ROOT / ".venv" / "bin" / "python"
    if win_venv.is_file():
        return str(win_venv)
    if posix_venv.is_file():
        return str(posix_venv)
    return sys.executable


def main() -> int:
    if not ORCHESTRATOR_PATH.is_file():
        print(f"[pre-commit WARN] orchestrator not found at {ORCHESTRATOR_PATH}; "
              "skipping checks. Restore from git OR re-run after merge.",
              file=sys.stderr)
        return 0

    python_exe = _venv_python()
    try:
        result = subprocess.run(
            [python_exe, str(ORCHESTRATOR_PATH), "--no-audit"],
            cwd=str(REPO_ROOT), timeout=180,
        )
    except (OSError, subprocess.SubprocessError, subprocess.TimeoutExpired) as exc:
        print(f"[pre-commit WARN] orchestrator invocation failed ({exc}); "
              "not blocking commit. Check Python venv + orchestrator path.",
              file=sys.stderr)
        return 0
    return result.returncode


if __name__ == "__main__":
    sys.exit(main())
